{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RSwitcher",
  "version": "0.1.4-alpha",
  "identifier": "com.rswitcher.desktop",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdn.jsdelivr.net; font-src 'self' https://fonts.gstatic.com https://cdn.jsdelivr.net; img-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost"
    },
    "windows": [
      {
        "title": "RSwitcher — Settings",
        "width": 640,
        "height": 560,
        "minWidth": 640,
        "maxWidth": 640,
        "minHeight": 520,
        "maxHeight": 860,
        "resizable": true,
        "fullscreen": false,
        "visible": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
