{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RSwitcher",
  "version": "0.1.1-alpha",
  "identifier": "com.rswitcher.desktop",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "RSwitcher — Настройки",
        "width": 480,
        "height": 570,
        "minWidth": 480,
        "maxWidth": 480,
        "minHeight": 570,
        "maxHeight": 900,
        "resizable": true,
        "fullscreen": false,
        "visible": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
